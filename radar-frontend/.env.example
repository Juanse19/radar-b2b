# ═══════════════════════════════════════════════════════════════════
# Matec Radar Comercial B2B — Variables de entorno requeridas
# ═══════════════════════════════════════════════════════════════════
# Copia este archivo como .env (producción) o .env.local (desarrollo)
# y rellena los valores reales. NUNCA subas .env o .env.local al repo.
# ═══════════════════════════════════════════════════════════════════

# ── Auth — iron-session ───────────────────────────────────────────
# Genera con: openssl rand -hex 32
SESSION_SECRET=

# ── N8N — 3 agentes encadenados ───────────────────────────────────
N8N_HOST=https://n8n.tu-servidor.com
N8N_API_KEY=

# WF01 (Calificador) was removed in V2 — qualification runs in-process via
# /api/comercial/calificar (SSE). No n8n env vars needed for it.

# WF02 — Radar de Inversión
N8N_RADAR_WORKFLOW_ID=
N8N_RADAR_WEBHOOK_PATH=radar-scan

# WF03 — Prospector
N8N_PROSPECT_WORKFLOW_ID=
N8N_PROSPECT_WEBHOOK_PATH=prospector

# ── Google Sheets (lectura) ───────────────────────────────────────
GOOGLE_SHEETS_API_KEY=
BASE_DE_DATOS_SHEET_ID=
LOG_SHEET_ID=

# ── Supabase (self-hosted) ────────────────────────────────────────
SUPABASE_URL=https://supabase.tu-servidor.com
SUPABASE_ANON_KEY=
# SERVICE_ROLE_KEY — solo server-side, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=matec_radar

# Públicas (accesibles desde el browser)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.tu-servidor.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Base de datos ─────────────────────────────────────────────────
# Para producción usar supabase (no prisma/SQLite)
DB_DRIVER=supabase
# DATABASE_URL solo necesario si DB_DRIVER=prisma
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
