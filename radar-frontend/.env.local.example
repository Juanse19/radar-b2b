# ── Claude API ────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── Feature flag Comercial module ────────────────────────────
NEXT_PUBLIC_RADAR_V2_ENABLED=true

# ── OpenAI (embeddings — text-embedding-3-small → 1536 dims) ─
OPENAI_API_KEY=

# ── Pinecone (RAG — índice matec-radar, dim=1536) ─────────────
PINECONE_API_KEY=
PINECONE_INDEX=matec-radar
PINECONE_NAMESPACE_COMERCIAL=comercial_dev
PINECONE_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://supabase.valparaiso.cafe
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_DB_SCHEMA=matec_radar

NEXT_PUBLIC_SUPABASE_URL=https://supabase.valparaiso.cafe
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# ── N8N ───────────────────────────────────────────────────────
N8N_HOST=https://n8n.event2flow.com
N8N_WEBHOOK_PATH=calificador

# ── Session signing (iron-session) ────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret-at-least-32-chars-replace-in-production
